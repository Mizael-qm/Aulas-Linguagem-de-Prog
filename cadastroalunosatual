<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📚 Sistema Escolar Dom Jaime</title>

    <style>
        :root {
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --bg-body: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.95);
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        body {
            background-color: var(--bg-body);
            background-image: radial-gradient(at 0% 0%, rgba(37, 99, 235, 0.05) 0px, transparent 50%),
                              radial-gradient(at 100% 100%, rgba(37, 99, 235, 0.05) 0px, transparent 50%);
            min-height: 100vh;
            color: var(--text-main);
        }

        /* Menu de Navegação */
        .menu {
            background: var(--white);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 5%;
            height: 70px;
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .menu-esquerda {
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--primary);
            letter-spacing: -0.5px;
        }

        .menu-centro {
            display: flex;
            gap: 10px;
        }

        .menu-centro span {
            padding: 8px 16px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: 0.2s;
            border-radius: 8px;
        }

        .menu-centro span:hover {
            color: var(--primary);
            background: rgba(37, 99, 235, 0.08);
        }

        .menu-direita span {
            background: var(--primary);
            color: white;
            padding: 10px 24px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .menu-direita span:hover {
            background: var(--primary-hover);
        }

        /* Container de Conteúdo */
        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .titulo {
            text-align: center;
            margin-bottom: 30px;
        }

        .titulo h1 { font-size: 24px; color: var(--text-main); }
        .titulo p { color: var(--text-muted); font-size: 15px; }

        /* Páginas e Formulários */
        .pagina {
            display: none;
            background: var(--glass);
            padding: 40px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .pagina-ativa {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        form {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .full-width { grid-column: span 2; }

        label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 6px;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            outline: none;
            transition: 0.2s;
        }

        input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .cadastrar {
            grid-column: span 2;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .cadastrar:hover { background: var(--primary-hover); }

        /* Dashboard Cards */
        #dashboard {
            display: none; /* Controlado pelo JS */
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        #dashboard.pagina-ativa { display: grid; }

        .card {
            background: var(--white);
            padding: 30px;
            border-radius: 16px;
            text-align: left;
            box-shadow: var(--shadow);
            border-left: 5px solid var(--primary);
        }

        .card h2 { font-size: 14px; color: var(--text-muted); text-transform: uppercase; }
        .card p { font-size: 32px; font-weight: 800; color: var(--text-main); margin-top: 10px; }

    </style>
</head>

<body>
    <div class="menu">
        <div class="menu-esquerda">🏫 DOM JAIME</div>
        <div class="menu-centro">
            <span onclick="navegar('dashboard')">Início</span>
            <span onclick="navegar('alunos')">Alunos</span>
            <span onclick="navegar('professores')">Professores</span>
            <span onclick="navegar('funcionarios')">Funcionários</span>
        </div>
        <div class="menu-direita">
            <span>Sair</span>
        </div>
    </div>

    <div class="container">
        
        <div id="dashboard" class="pagina pagina-ativa">
            <div class="card">
                <h2>Alunos Cadastrados</h2>
                <p id="count-alunos">124</p>
            </div>
            <div class="card">
                <h2>Docentes Ativos</h2>
                <p id="count-profs">18</p>
            </div>
            <div class="card">
                <h2>Corpo Técnico</h2>
                <p id="count-func">12</p>
            </div>
        </div>

        <div id="alunos" class="pagina">
            <div class="titulo">
                <h1>Ficha do Aluno</h1>
                <p>Preencha os dados para nova matrícula</p>
            </div>
            <form>
                <div class="full-width">
                    <label>Nome Completo</label>
                    <input type="text" placeholder="Ex: João Silva">
                </div>
                <div>
                    <label>Data de Nascimento</label>
                    <input type="date">
                </div>
                <div>
                    <label>CPF</label>
                    <input type="text" placeholder="000.000.000-00">
                </div>
                <div class="full-width">
                    <label>E-mail</label>
                    <input type="email" placeholder="email@exemplo.com">
                </div>
                <button type="button" class="cadastrar" onclick="alert('Aluno cadastrado!')">Salvar Matrícula</button>
            </form>
        </div>

        <div id="professores" class="pagina">
            <div class="titulo">
                <h1>Ficha do Professor</h1>
                <p>Cadastro de novos docentes</p>
            </div>
            <form>
                <div class="full-width">
                    <label>Nome do Docente</label>
                    <input type="text">
                </div>
                <div>
                    <label>Disciplina</label>
                    <input type="text" placeholder="Ex: Matemática">
                </div>
                <div>
                    <label>CPF</label>
                    <input type="text">
                </div>
                <button type="button" class="cadastrar" onclick="alert('Professor cadastrado!')">Cadastrar Docente</button>
            </form>
        </div>

        <div id="funcionarios" class="pagina">
            <div class="titulo">
                <h1>Ficha de Funcionário</h1>
                <p>Registro de equipe administrativa e apoio</p>
            </div>
            <form>
                <div class="full-width">
                    <label>Nome Completo</label>
                    <input type="text">
                </div>
                <div>
                    <label>Cargo</label>
                    <input type="text" placeholder="Ex: Secretário">
                </div>
                <div>
                    <label>CPF</label>
                    <input type="text">
                </div>
                <button type="button" class="cadastrar" onclick="alert('Funcionário cadastrado!')">Salvar Registro</button>
            </form>
        </div>

    </div>

    <script>
        function navegar(idPagina) {
            // Esconde todas as páginas
            const paginas = document.querySelectorAll('.pagina');
            paginas.forEach(p => p.classList.remove('pagina-ativa'));

            // Mostra a página alvo
            document.getElementById(idPagina).classList.add('pagina-ativa');
        }
    </script>
</body>

</html>
